rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is admin
    function isAdmin() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Admin';
    }

    // Rules for the 'feedback' collection
    match /feedback/{feedbackId} {
      // Allow anyone to create new feedback documents
      allow create: if true;
      // Only admins can read
      allow read: if isAdmin();
    }

    // Rules for the 'inquiries' collection
    match /inquiries/{inquiryId} {
      // Allow anyone to create new inquiry documents
      allow create: if true;
      // Only admins can read
      allow read: if isAdmin();
    }

    // Portfolio projects (public read, admin write)
    match /portfolio/{projectId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Home page featured project cards (public read, admin write)
    match /featuredProjects/{projectId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Clients (public read, admin write)
    match /clients/{clientId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Ongoing clients (public read, admin write)
    match /ongoingClients/{entryId} {
      allow read: if true;
      allow create, update, delete: if request.auth != null && isAdmin();
    }

    // Helper: check if user is Business Associate
    function isBusinessAssociate() {
      return request.auth != null &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'Business Associate';
    }

    // Potential clients (Business Associates: own docs only; Admins: all)
    match /potentialClients/{clientId} {
      allow create: if request.auth != null && isBusinessAssociate() &&
        request.resource.data.addedBy == request.auth.uid;
      allow read, update, delete: if request.auth != null &&
        (isAdmin() || resource.data.addedBy == request.auth.uid);
    }

    // Rules for the 'users' collection
    match /users/{userId} {
      // Users can read their own data
      allow read: if request.auth != null && request.auth.uid == userId;
      // Admins can read all user data
      allow read: if isAdmin();
      // Users can update their own data
      allow update: if request.auth != null && request.auth.uid == userId;
      // Admins can create and update user data
      allow create, update: if isAdmin();
      // Allow creating super admin user (first admin)
      allow create: if request.auth != null &&
                       request.auth.uid == userId &&
                       request.resource.data.email == 'super@gmail.com' &&
                       request.resource.data.role == 'Admin';
    }

    // Mail settings (admin only) – Gmail / Nodemailer config
    match /settings/mail {
      allow read, write: if isAdmin();
    }

    // Offer letter / company settings: admins write; authenticated users read (for profile offer letter)
    match /settings/offerLetter {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Catch-all: block all other collections
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
