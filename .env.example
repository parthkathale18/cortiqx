# Copy to .env and fill from Firebase Console → Project settings → Your apps (Web).
# https://console.firebase.google.com/

# Canonical origin for SEO (Open Graph, JSON-LD, sitemap URLs). No trailing slash.
# VITE_SITE_URL=https://cortiqx.in

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Firestore: forced long-polling reduces QUIC/WebChannel issues in Chrome (default: on).
# Set to false or 0 to use default transport (slightly higher throughput on stable networks).
# VITE_FIRESTORE_LONG_POLLING=false

# Optional: absolute URL if send-mail is not same-origin /api/sendMail
# VITE_SEND_MAIL_URL=https://your-domain.com/api/sendMail

# Optional: override consultation mail API (default same-origin /api/sendConsultation on Vercel)
# VITE_CONSULTATION_API_URL=https://your-domain.com/api/sendConsultation

# --- Vercel / server only (Book consultation emails — set in Vercel Project → Environment Variables) ---
# CONSULTATION_NOTIFY_EMAIL=you@yourdomain.com
# MAIL_FROM="CortiqX <hello@yourdomain.com>"
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=hello@yourdomain.com
# SMTP_PASS=your-app-password
